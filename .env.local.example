# Supabase — copy from your project's settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# NEW key system (Settings → API Keys): publishable for the browser.
# The legacy anon/service_role JWT keys are deprecated; the code falls back
# to NEXT_PUBLIC_SUPABASE_ANON_KEY only until the new key is set.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Postgres connection string (Connect → Session pooler) — used ONLY by
# scripts/run-migration.mjs and scripts/db-read.mjs, never by the app.
# The runner refuses to run if this points at a different project than
# NEXT_PUBLIC_SUPABASE_URL.
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres
